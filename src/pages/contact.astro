---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Contact">

<h1>Contact & Booking</h1>

<p>
Book your mountain adventure in Željezno Polje.
Fill out the form below or contact us directly.
</p>

<div class="contact-info">

<p><strong>Email:</strong> efendicredzo4@gmail.com</p>
<p><strong>Phone / Viber:</strong> +387 61 562 762</p>

</div>


<h2>Book Your Experience</h2>

<form class="booking-form">

<input type="text" placeholder="Full Name" required>

<input type="email" placeholder="Email Address" required>

<input type="number" placeholder="Number of Guests" required>

<input type="date" required>

<textarea placeholder="Message (optional)" rows="4"></textarea>

<button type="submit">Send Booking Request</button>

</form>

</MainLayout>


<style>

.contact-info{
margin:20px 0 40px 0;
font-size:18px;
}

.booking-form{
max-width:500px;
display:flex;
flex-direction:column;
gap:15px;
}

.booking-form input,
.booking-form textarea{
padding:12px;
font-size:16px;
border-radius:6px;
border:1px solid #ccc;
}

.booking-form button{
padding:14px;
background:#2e7d32;
color:white;
border:none;
border-radius:8px;
font-size:18px;
cursor:pointer;
}

.booking-form button:hover{
background:#1b5e20;
}

</style>