---
import MainLayout from "../layouts/MainLayout.astro";
const base = import.meta.env.BASE_URL;
---

<MainLayout title="Mountain Experience">

<section class="hero-exp">

<div class="hero-content">
<h1>Mahnjača Mountain Experience</h1>

<p>
Spend an unforgettable day in the mountains of Željezno Polje.
Discover nature, traditional Bosnian food and authentic village life.
</p>

<a href={base + 'contact'} class="hero-btn">Book Your Adventure</a>
</div>

</section>


<section class="timeline">

<h2>A Day on the Mountain</h2>

<div class="timeline-grid">

<div class="time-card">
<h3>09:00</h3>
<p>Arrival in Željezno Polje and welcome with fresh mountain spring water.</p>
</div>

<div class="time-card">
<h3>10:00</h3>
<p>Tractor ride with trailer to Mahnjača mountain or</p>
</div>

<div class="time-card">
<h3>10:00</h3>
<p>Guided hiking through forests and mountain trails.</p>
</div>

<div class="time-card">
<h3>13:00</h3>
<p>Cooking traditional Bosnian potato pie (krompiruša) under the sač.</p>
</div>

<div class="time-card">
<h3>14:30</h3>
<p>Lunch with organic raspberries, blackberries and local food. 
  Tasting traditional sheep cheese made by local shepherds.</p>
</div>

<div class="time-card">
<h3>16:00</h3>
<p>Relaxation in nature and return to the village.</p>
</div>

</div>

</section>


<section class="pricing">

<h2>Price</h2>

<div class="price-card">

<h3>Mountain Experience</h3>

<p class="price">€50 per person</p>

<ul>
<li>✔ Tractor ride to the mountain</li>
<li>✔ Guided hiking tour</li>
<li>✔ Traditional Bosnian lunch</li>
<li>✔ Tasting traditional sheep cheese (Requires Aditional Payment)</li>
<li>✔ Cooking pie under the sač</li>
<li>✔ Organic berry tasting</li>
</ul>

<a href={base + 'contact'} class="btn">Reserve Your Spot</a>

</div>

</section>


<section class="map">

<h2>Location</h2>

<iframe
src="https://maps.google.com/maps?q=Zeljezno%20Polje%20Bosnia&t=&z=13&ie=UTF8&iwloc=&output=embed"
width="100%"
height="400"
style="border:0;border-radius:10px;"
loading="lazy">
</iframe>

</section>


<section class="reviews">

<h2>What Our Visitors Say</h2>

<div class="review-grid">

<div class="review-card">
<p>★★★★★</p>
<p>"One of the most authentic experiences in Bosnia. The food and nature were amazing."</p>
<strong>John – UK</strong>
</div>

<div class="review-card">
<p>★★★★★</p>
<p>"The tractor ride and mountain views were unforgettable!"</p>
<strong>Sarah – England</strong>
</div>

<div class="review-card">
<p>★★★★★</p>
<p>"Cooking Bosnian pie under the sač was the highlight of our trip."</p>
<strong>Michael – London</strong>
</div>

</div>

</section>


<section class="gallery">

<h2>Gallery</h2>

<div class="gallery-grid">

<img src={base + 'mountain.jpg'} alt="Mahnjača mountain">
<img src={base + 'tractor.jpg'} alt="Tractor ride">
<img src={base + 'pie.jpg'} alt="Bosnian pie">
<img src={base + 'raspberries.jpg'} alt="Organic raspberries">
<img src={base + 'village.jpg'} alt="Željezno Polje village">
<img src={base + 'forest.jpg'} alt="Mountain forest">

</div>

</section>


<section class="book-cta">

<h2>Ready for your mountain adventure?</h2>

<p>
Book your experience today and discover authentic Bosnian mountain life.
</p>

<a href={base + 'contact'} class="btn">Book Your Experience</a>

</section>

</MainLayout>



<style>

/* HERO */

.hero-exp{
height:420px;
background-size:cover;
background-position:center;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
color:white;
border-radius:10px;
}

.hero-content{
background:rgba(0,0,0,0.4);
padding:40px;
border-radius:10px;
max-width:700px;
}

.hero-exp h1{
font-size:48px;
margin-bottom:20px;
}

.hero-btn{
display:inline-block;
margin-top:20px;
padding:14px 28px;
background:#2e7d32;
color:white;
text-decoration:none;
border-radius:8px;
font-size:18px;
transition:background 0.2s ease;
}

.hero-btn:hover{
background:#1b5e20;
}


/* TIMELINE */

.timeline{
margin-top:80px;
text-align:center;
}

.timeline h2{
font-size:36px;
margin-bottom:40px;
color:#1f3d2b;
}

.timeline-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
padding:0 10px;
}

.time-card{
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 6px 18px rgba(0,0,0,0.08);
}

.time-card h3{
color:#2e7d32;
}


/* PRICING */

.pricing{
margin-top:80px;
text-align:center;
}

.price-card{
max-width:350px;
margin:auto;
background:white;
padding:35px;
border-radius:12px;
box-shadow:0 8px 22px rgba(0,0,0,0.1);
}

.price{
font-size:32px;
color:#2e7d32;
margin:20px 0;
}


/* MAP */

.map{
margin-top:80px;
text-align:center;
padding:0 10px;
}

.map h2{
margin-bottom:30px;
color:#1f3d2b;
}


/* REVIEWS */

.reviews{
margin-top:80px;
text-align:center;
}

.review-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
margin-top:30px;
padding:0 10px;
}

.review-card{
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 6px 18px rgba(0,0,0,0.08);
}


/* GALLERY */

.gallery{
margin-top:80px;
text-align:center;
}

.gallery-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
margin-top:30px;
padding:0 10px;
}

.gallery-grid img{
width:100%;
height:180px;
object-fit:cover;
border-radius:12px;
box-shadow:0 6px 18px rgba(0,0,0,0.1);
transition:transform 0.3s;
}

.gallery-grid img:hover{
transform:scale(1.05);
}


/* CTA */

.book-cta{
margin-top:80px;
text-align:center;
background:#e8f5e9;
padding:50px;
border-radius:10px;
}


/* ===================== */
/* 📱 MOBILE */
/* ===================== */

@media (max-width: 768px) {

  /* HERO */

  .hero-exp{
    height:auto;
    padding:80px 15px;
    border-radius:0;
  }

  .hero-content{
    padding:25px;
  }

  .hero-exp h1{
    font-size:32px;
  }

  .hero-btn{
    width:100%;
    padding:14px;
  }

  /* TIMELINE */

  .timeline{
    margin-top:50px;
  }

  .timeline h2{
    font-size:26px;
  }

  .time-card{
    padding:20px;
  }

  /* PRICING */

  .pricing{
    margin-top:50px;
  }

  .price-card{
    padding:25px;
  }

  /* MAP */

  .map{
    margin-top:50px;
  }

  iframe{
    height:300px;
  }

  /* REVIEWS */

  .reviews{
    margin-top:50px;
  }

  /* GALLERY */

  .gallery{
    margin-top:50px;
  }

  .gallery-grid img{
    height:150px;
  }

  /* CTA */

  .book-cta{
    margin-top:50px;
    padding:30px 20px;
  }

}


/* ===================== */
/* 📱 SMALL DEVICES */
/* ===================== */

@media (max-width: 480px) {

  .hero-exp h1{
    font-size:28px;
  }

  .gallery-grid img{
    height:130px;
  }

}

</style>