---
import MainLayout from "../layouts/MainLayout.astro";
const base = import.meta.env.BASE_URL;
---

<MainLayout title="Tours">

<section class="hero">

<h1>Our Mountain Experiences</h1>

<p>
Discover authentic adventures in Željezno Polje – hiking, traditional food
and real Bosnian village life.
</p>

</section>


<section class="tours">

<h2>Our Experiences</h2>

<div class="tour-grid">

<div class="tour-card">
<img src={base + 'mountain.jpg'} alt="Mountain hiking">

<h3>🥾 Mountain Hiking</h3>

<p>
Explore beautiful mountain trails around Mahnjača and enjoy
fresh air, forests, spring water and amazing views.
</p>

</div>


<div class="tour-card">

<img src={base + 'tractor.jpg'} alt="Tractor ride">

<h3>🚜 Tractor Mountain Ride</h3>

<p>
Ride a traditional tractor with a trailer to the mountain
and experience authentic village life.
</p>

</div>


<div class="tour-card">

<img src={base + 'pie.jpg'} alt="Bosnian pie">

<h3>🥧 Bosnian Pie Tasting</h3>

<p>
Taste traditionally prepared Bosnian potato pie baked under the sač.
</p>

</div>


<div class="tour-card">

<img src={base + 'cheese.jfif'} alt="Sheep cheese">

<h3>🧀 Traditional Sheep Cheese</h3>

<p>
  Meet local shepherds and taste authentic homemade sheep cheese on Mahnjača.
</p>

</div>

</div>

</section>


<section class="extra-info">

<h2>About the Mahnjača Hiking Route</h2>

<p>
The hiking route on Mahnjača mountain was developed by local
mountaineers and residents of Željezno Polje. The trail passes
through forests, mountain springs and scenic viewpoints with
beautiful views of central Bosnia.
</p>

<p>
You can read the full story about the creation of the hiking route
in the article published on Balkan Diskurs.
</p>

<a 
href="https://balkandiskurs.com/en/2021/08/03/new-hiking-route-mahnjaca/"
target="_blank"
class="btn">
Read the Full Article
</a>

</section>


<section class="cta">

<h2>Ready for Your Adventure?</h2>

<p>
Join us for an unforgettable mountain experience in Bosnia.
</p>

<a href={base + 'contact'} class="btn">Book Your Tour</a>

</section>


<style>

/* HERO */

.hero{
text-align:center;
padding:120px 20px;
background:#e8f5e9;
border-radius:10px;
}

.hero h1{
font-size:46px;
margin-bottom:15px;
}

.hero p{
font-size:18px;
max-width:700px;
margin:auto;
line-height:1.5;
}


/* TOURS */

.tours{
margin-top:70px;
text-align:center;
}

.tours h2{
font-size:36px;
margin-bottom:40px;
color:#1f3d2b;
}

.tour-grid{
display:grid;
grid-template-columns:repeat(auto-fit, minmax(260px, 1fr));
gap:30px;
max-width:1100px;
margin:auto;
padding:0 10px;
}

.tour-card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.08);
transition:transform 0.2s ease, box-shadow 0.2s ease;
}

.tour-card:hover{
transform:translateY(-6px);
box-shadow:0 12px 25px rgba(0,0,0,0.15);
}

.tour-card img{
width:100%;
height:180px;
object-fit:cover;
border-radius:8px;
margin-bottom:15px;
}

.tour-card h3{
font-size:22px;
margin-bottom:10px;
color:#2e7d32;
}

.tour-card p{
font-size:16px;
line-height:1.6;
}


/* EXTRA INFO */

.extra-info{
margin-top:80px;
background:#f1f8e9;
padding:40px;
border-radius:10px;
text-align:center;
max-width:900px;
margin-left:auto;
margin-right:auto;
}

.extra-info h2{
margin-bottom:20px;
color:#1f3d2b;
}

.extra-info p{
margin-bottom:15px;
line-height:1.5;
}


/* CTA */

.cta{
margin-top:80px;
text-align:center;
background:#e8f5e9;
padding:50px;
border-radius:10px;
}


/* ===================== */
/* 📱 MOBILE */
/* ===================== */

@media (max-width: 768px) {

  /* HERO */

  .hero{
    padding:80px 15px;
    border-radius:0;
  }

  .hero h1{
    font-size:32px;
  }

  .hero p{
    font-size:16px;
  }

  /* TOURS */

  .tours{
    margin-top:50px;
  }

  .tours h2{
    font-size:26px;
  }

  .tour-grid{
    gap:20px;
  }

  .tour-card{
    padding:20px;
  }

  .tour-card img{
    height:160px;
  }

  /* EXTRA INFO */

  .extra-info{
    padding:25px 15px;
    margin-top:50px;
  }

  .extra-info h2{
    font-size:22px;
  }

  /* CTA */

  .cta{
    padding:30px 20px;
    margin-top:50px;
  }

}


/* ===================== */
/* 📱 SMALL DEVICES */
/* ===================== */

@media (max-width: 480px) {

  .hero h1{
    font-size:28px;
  }

  .tour-card img{
    height:140px;
  }

}

</style>

</MainLayout>