---
import MainLayout from "../layouts/MainLayout.astro";
const base = import.meta.env.BASE_URL;
---

<MainLayout title="Iron Valley Adventures">

<section class="hero">

<h1>Iron Valley Adventures</h1>

<p>
Experience authentic mountain life in Željezno Polje.
Hiking, tractor rides, traditional Bosnian food and organic berries
in the beautiful nature of Bosnia and Herzegovina.
</p>

<a href={base + 'tours'} class="hero-btn">Explore Tours</a>

</section>


<section class="intro">

<h2>Discover Authentic Mountain Life in Bosnia</h2>

<p>
Experience nature, traditional food, and real village life
in the beautiful village of Željezno Polje.
</p>

<a href={base + 'contact'} class="btn">Book Your Adventure</a>

</section>


<section class="offers">

<h2>What We Offer</h2>

<div class="offer-grid">

<div class="offer-card">
<h3>🥾 Mountain Hiking</h3>
<p>Explore beautiful mountain trails around Mahnjača.</p>
</div>

<div class="offer-card">
<h3>🚜 Tractor Ride</h3>
<p>Ride a traditional tractor with a trailer to the mountain.</p>
</div>

<div class="offer-card">
<h3>🍲 Traditional Lunch</h3>
<p>Enjoy authentic Bosnian homemade food in nature.</p>
</div>

<div class="offer-card">
<h3>🍓 Organic Berries</h3>
<p>Taste fresh raspberries and blackberries from the mountains.</p>
</div>

<div class="offer-card">
<h3>🥧 Bosnian Pie</h3>
<p>Taste traditional Bosnian pie prepared under the sač.</p>
</div>

<div class="offer-card">
<h3>🧀 Sheep Cheese</h3>
<p>
 Taste traditional sheep cheese made by local shepherds on Mahnjača.
</p>
</div>

</div>

</section>


<style>
/* HERO */

.hero {
  position: relative;
  text-align: center;
  padding: 140px 20px;
  background-image: url("mountain.jpg");
  background-size: cover;
  background-position: center;
  color: white;
  overflow: hidden;
  border-radius: 0; 
}

.hero::before{
content:"";
position:absolute;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,0.45);
}

.hero h1,
.hero p,
.hero-btn{
position:relative;
z-index:2;
}

.hero h1{
font-size:64px;
margin-bottom:20px;
font-weight:700;
}

.hero p{
font-size:22px;
max-width:700px;
margin:auto;
line-height:1.5;
}

.hero-btn{
display:inline-block;
margin-top:30px;
padding:16px 34px;
background:#2e7d32;
color:white;
text-decoration:none;
font-size:18px;
border-radius:8px;
transition:background 0.2s ease;
}

.hero-btn:hover{
background:#1b5e20;
}


/* INTRO */

.intro{
margin-top:80px;
text-align:center;
max-width:800px;
margin-left:auto;
margin-right:auto;
padding:0 10px;
}

.intro h2{
margin-bottom:15px;
color:#1f3d2b;
}

.intro p{
font-size:18px;
margin-bottom:25px;
line-height:1.5;
}


/* OFFERS */

.offers{
margin-top:80px;
text-align:center;
}

.offers h2{
margin-bottom:40px;
color:#1f3d2b;
}

.offer-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
}

.offer-card{
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 6px 18px rgba(0,0,0,0.08);
transition:transform 0.25s;
}

.offer-card:hover{
transform:translateY(-6px);
}

.offer-card h3{
margin-bottom:10px;
}


/* ===================== */
/* 📱 MOBILE */
/* ===================== */

/* MOBILE FIX */
@media (max-width: 768px) {

  .hero {
    padding: 100px 15px;
    margin: 0 -20px; /* 🔥 FULL WIDTH FIX */
    border-radius: 0;
  }

  .hero h1 {
    font-size: 34px;
  }

  .hero p {
    font-size: 16px;
  }

  .hero-btn {
    width: 100%;
    max-width: 280px;
  }


  /* INTRO */

  .intro{
    margin-top:50px;
  }

  .intro h2{
    font-size:22px;
  }

  /* OFFERS */

  .offers{
    margin-top:50px;
  }

  .offer-card{
    padding:20px;
  }

}


/* ===================== */
/* 📱 SMALL DEVICES */
/* ===================== */

@media (max-width: 480px) {

  .hero h1{
    font-size:30px;
  }

  .hero p{
    font-size:16px;
  }

}

</style>

</MainLayout>