---
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>

<!-- Favicon -->
<link rel="icon" href={`${base}favicon.png`} />

<style>
/* RESET */

* {
  box-sizing: border-box;
}

/* BODY */

body {
  font-family: Arial, sans-serif;
  margin: 0;
  background: #e8f5e9;
  color: #333;
}

/* NAVBAR */

header {
  background: #1f3d2b;
  padding: 15px 0;
}

.navbar {
  max-width: 1100px;
  margin: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
}

/* LOGO */

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  color: white;
  text-decoration: none;
  font-weight: bold;
  font-size: 20px;
}

.logo img {
  height: 45px;
}

/* NAV LINKS */

nav {
  display: flex;
  gap: 30px;
}

nav a {
  color: white;
  text-decoration: none;
  font-weight: bold;
  font-size: 17px;
  transition: opacity 0.2s ease;
}

nav a:hover {
  opacity: 0.8;
}

/* PAGE CONTENT */

.container {
  max-width: 900px;
  margin: auto;
  padding: 40px 20px;
}

/* BUTTON */

.btn {
  display: inline-block;
  margin-top: 20px;
  padding: 12px 25px;
  background: #2e7d32;
  color: white;
  text-decoration: none;
  border-radius: 6px;
  transition: background 0.2s ease;
}

.btn:hover {
  background: #1b5e20;
}

/* FOOTER */

footer {
  margin-top: 60px;
  background: #1f3d2b;
  color: white;
  text-align: center;
  padding: 20px;
}

/* ===================== */
/* 📱 MOBILE RESPONSIVE */
/* ===================== */

@media (max-width: 768px) {

  /* NAVBAR */

  .navbar {
    flex-direction: column;
    align-items: center;
    gap: 15px;
  }

  .logo {
    justify-content: center;
  }

  nav {
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
  }

  nav a {
    font-size: 16px;
  }

  /* CONTENT */

  .container {
    padding: 20px 15px;
  }

  /* BUTTONS */

  .btn {
    width: 100%;
    text-align: center;
    padding: 14px;
  }

}

/* ===================== */
/* 📱 SMALL DEVICES */
/* ===================== */

@media (max-width: 480px) {

  .logo {
    font-size: 18px;
  }

  .logo img {
    height: 38px;
  }

  nav a {
    font-size: 15px;
  }

}

</style>

</head>
<body>

<header>
  <div class="navbar">
    <!-- LOGO -->
    <a href={base} class="logo">
      <img src={`${base}iron-valley-logo.png`} alt="Iron Valley Adventures" />
      <span>Iron Valley Adventures</span>
    </a>

    <!-- NAV LINKS -->
    <nav>
      <a href={base}>Home</a>
      <a href={base + 'tours'}>Tours</a>
      <a href={base + 'experience'}>Experience</a>
      <a href={base + 'contact'}>Contact</a>
    </nav>
  </div>
</header>

<!-- PAGE CONTENT -->
<div class="container">
  <slot />
</div>

<footer>
  <p>© 2026 Iron Valley Adventures</p>
</footer>

</body>
</html>