---
const { title } = Astro.props;
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>

<style>
body{
font-family: Arial, sans-serif;
margin:0;
background:#e8f5e9;
color:#333;
}

header{
background:#1f3d2b;
color:white;
padding:20px;
text-align:center;
}

/* NAVBAR */

nav{
margin-top:15px;
display:flex;
justify-content:center;
gap:30px;
}

nav a{
color:white;
text-decoration:none;
font-weight:bold;
font-size:18px;
}

nav a:hover{
text-decoration:underline;
}

.container{
max-width:900px;
margin:auto;
padding:40px 20px;
}

h1{
font-size:40px;
}

h2{
margin-top:40px;
color:#1f3d2b;
}

ul{
line-height:1.8;
}

.btn{
display:inline-block;
margin-top:20px;
padding:12px 25px;
background:#2e7d32;
color:white;
text-decoration:none;
border-radius:6px;
}

footer{
margin-top:60px;
background:#1f3d2b;
color:white;
text-align:center;
padding:20px;
}
</style>

</head>

<body>

<header>
<h1>Iron Valley Adventures</h1>
<p>Željezno Polje • Bosnia and Herzegovina</p>

<nav>
<a href="/">Home</a>
<a href="/tours">Tours</a>
<a href="/experience">Experience</a>
<a href="/contact">Contact</a>
</nav>

</header>

<div class="container">
<slot />
</div>

<footer>
<p>© 2026 Iron Valley Adventures</p>
</footer>

</body>
</html>